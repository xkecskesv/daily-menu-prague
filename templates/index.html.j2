<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Menička Praha — mai ebédmenük</title>
<meta name="description" content="Praha 1, 3, 7, 8 aznapi ebédmenüi egy helyen, szűrhetően és távolság szerint.">
<style>
:root{
  --paper:#ECE4D0;
  --paper-alt:#E2D8BE;
  --paper-deep:#D8CCA9;
  --ink:#22291F;
  --ink-soft:#4B5142;
  --pub-green:#2E4A3B;
  --pub-green-dark:#1D3126;
  --stamp-red:#A23A2C;
  --stamp-red-dark:#7E2B20;
  --brass:#A2803D;
  --line:#BEB090;
  --shadow:rgba(34,41,31,.22);
  --font-display:Georgia,'Iowan Old Style','Palatino Linotype','Book Antiqua',serif;
  --font-body:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
  --font-mono:'Courier New',Courier,monospace;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:
    radial-gradient(ellipse at top left, rgba(255,255,255,.25), transparent 55%),
    var(--paper);
  color:var(--ink);
  font-family:var(--font-body);
  line-height:1.45;
  -webkit-font-smoothing:antialiased;
}
a{color:inherit;}

/* ---------------- Fejléc: pult-tábla / pecsét hangulat ---------------- */
header.masthead{
  position:relative;
  background:
    repeating-linear-gradient(135deg, rgba(255,255,255,.04) 0 2px, transparent 2px 6px),
    linear-gradient(160deg, var(--pub-green) 0%, var(--pub-green-dark) 100%);
  color:#EFE9D8;
  padding:2.6rem 1.5rem 3rem;
  overflow:hidden;
}
.masthead-inner{
  max-width:1100px;
  margin:0 auto;
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap:2rem;
  flex-wrap:wrap;
}
.masthead h1{
  font-family:var(--font-display);
  font-weight:700;
  font-size:clamp(2.1rem,5vw,3.2rem);
  margin:0 0 .35rem;
  letter-spacing:.5px;
}
.masthead h1 small{
  display:block;
  font-family:var(--font-mono);
  font-size:.95rem;
  letter-spacing:3px;
  text-transform:uppercase;
  color:#C9BE9C;
  margin-bottom:.6rem;
}
.masthead p.tagline{
  margin:0;
  max-width:34em;
  color:#D8D1B8;
  font-size:.98rem;
}
.masthead p.districts{
  margin:.55rem 0 0;
  font-family:var(--font-mono);
  font-size:.85rem;
  color:#B9C9AE;
  letter-spacing:.5px;
}

/* pecsét-jelvény a mai dátummal */
.stamp{
  flex:none;
  width:118px;height:118px;
  border-radius:50%;
  border:3px solid #C9BE9C;
  outline:1px solid #C9BE9C;
  outline-offset:4px;
  display:flex;
  align-items:center;
  justify-content:center;
  transform:rotate(-9deg);
  color:#EFE9D8;
  text-align:center;
  font-family:var(--font-mono);
  text-transform:uppercase;
  letter-spacing:1px;
  opacity:.92;
  mix-blend-mode:normal;
  position:relative;
}
.stamp::before{
  content:"";
  position:absolute; inset:8px;
  border-radius:50%;
  border:1px dashed #C9BE9C;
}
.stamp .stamp-label{font-size:.62rem;letter-spacing:2px;opacity:.85;}
.stamp .stamp-date{font-size:.95rem;font-weight:700;margin-top:.2rem;line-height:1.15;}

/* perforáció-csík a fejléc alján, mintha egy jegy szélét néznénk */
.perforation{
  height:14px;
  background-image:radial-gradient(circle, var(--paper) 5px, transparent 5.5px);
  background-size:24px 24px;
  background-position:center -5px;
  background-repeat:repeat-x;
  background-color:var(--pub-green-dark);
  margin-top:-1px;
}

/* ---------------- Vezérlőpult (szűrők) ---------------- */
.toolbar{
  max-width:1100px;
  margin:-1.4rem auto 0;
  padding:0 1.5rem;
  position:relative;
  z-index:2;
}
.card-panel{
  background:var(--paper-alt);
  border:1px solid var(--line);
  box-shadow:0 10px 24px var(--shadow);
  border-radius:6px;
  padding:1.4rem 1.5rem 1.6rem;
}
.filter-row{
  display:flex;
  flex-wrap:wrap;
  gap:1.4rem 2rem;
  margin-bottom:1.1rem;
}
.filter-group{flex:1 1 220px;min-width:200px;}
.filter-group h3{
  font-family:var(--font-mono);
  text-transform:uppercase;
  font-size:.72rem;
  letter-spacing:1.6px;
  color:var(--ink-soft);
  margin:0 0 .55rem;
  border-bottom:1px dotted var(--line);
  padding-bottom:.35rem;
}
.chip-row{display:flex;flex-wrap:wrap;gap:.45rem;}
.chip{
  font-family:var(--font-body);
  font-size:.83rem;
  padding:.34rem .75rem;
  border:1px solid var(--pub-green);
  border-radius:999px;
  background:transparent;
  color:var(--pub-green-dark);
  cursor:pointer;
  transition:background .15s, color .15s, transform .1s;
  user-select:none;
}
.chip:hover{transform:translateY(-1px);}
.chip.active{
  background:var(--pub-green);
  color:#F2EDDC;
  border-color:var(--pub-green);
}
.chip.cuisine.active{background:var(--brass);border-color:var(--brass);color:#2A2110;}
.chip.stamp-style.active{background:var(--stamp-red);border-color:var(--stamp-red);color:#F7EDE8;}

.search-input{
  width:100%;
  padding:.55rem .7rem;
  font-family:var(--font-body);
  font-size:.92rem;
  border:1px solid var(--line);
  border-radius:4px;
  background:var(--paper);
  color:var(--ink);
}
.search-input:focus{outline:2px solid var(--brass);outline-offset:1px;}

.range-wrap{position:relative;height:34px;margin-top:.3rem;}
.range-wrap input[type=range]{
  position:absolute;top:10px;left:0;width:100%;
  -webkit-appearance:none;appearance:none;
  background:transparent;pointer-events:none;
}
.range-wrap input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;pointer-events:auto;
  width:16px;height:16px;border-radius:50%;
  background:var(--pub-green);border:2px solid var(--paper);
  cursor:pointer;margin-top:-6px;
}
.range-wrap input[type=range]::-moz-range-thumb{
  pointer-events:auto;width:16px;height:16px;border-radius:50%;
  background:var(--pub-green);border:2px solid var(--paper);cursor:pointer;
}
.range-wrap input[type=range]::-webkit-slider-runnable-track{height:3px;background:var(--line);}
.range-wrap input[type=range]::-moz-range-track{height:3px;background:var(--line);}
.range-values{
  font-family:var(--font-mono);
  font-size:.85rem;
  color:var(--ink-soft);
  margin-top:.15rem;
}

.ref-toggle{display:flex;gap:.5rem;flex-wrap:wrap;}
.ref-toggle label{
  font-size:.83rem;
  border:1px solid var(--line);
  border-radius:4px;
  padding:.4rem .6rem;
  cursor:pointer;
  display:flex;align-items:center;gap:.4rem;
  background:var(--paper);
}
.ref-toggle input{accent-color:var(--pub-green);}
.ref-toggle .desc{display:block;font-size:.72rem;color:var(--ink-soft);}

.toolbar-bottom{
  display:flex;
  flex-wrap:wrap;
  align-items:center;
  justify-content:space-between;
  gap:.8rem;
  border-top:1px dotted var(--line);
  padding-top:1rem;
}
.sort-select{
  font-family:var(--font-body);
  font-size:.85rem;
  padding:.4rem .55rem;
  border:1px solid var(--line);
  border-radius:4px;
  background:var(--paper);
  color:var(--ink);
}
.btn{
  font-family:var(--font-mono);
  letter-spacing:.5px;
  font-size:.85rem;
  padding:.55rem 1rem;
  border-radius:4px;
  border:1px solid var(--stamp-red);
  background:var(--stamp-red);
  color:#F7EDE8;
  cursor:pointer;
  transition:transform .12s, box-shadow .12s;
}
.btn:hover{transform:translateY(-1px);box-shadow:0 4px 10px rgba(162,58,44,.35);}
.btn.ghost{
  background:transparent;border-color:var(--ink-soft);color:var(--ink-soft);
}
.reset-link{
  background:none;border:none;
  font-family:var(--font-mono);font-size:.78rem;
  text-decoration:underline;color:var(--ink-soft);cursor:pointer;
  padding:0;
}

.meta-row{
  max-width:1100px;margin:1rem auto 0;padding:0 1.5rem;
  display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem;
}
.result-count{
  font-family:var(--font-mono);
  font-size:.85rem;
  color:var(--ink-soft);
}
.result-count strong{color:var(--pub-green-dark);font-size:1rem;}

/* ---------------- Étterem-jegyek (kártyák) ---------------- */
main.board{
  max-width:1100px;margin:1rem auto 4rem;padding:0 1.5rem;
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:1.3rem;
  align-items:start;
}
.ticket{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:4px;
  box-shadow:0 6px 14px var(--shadow);
  padding:1.1rem 1.15rem 1rem;
  position:relative;
  transition:box-shadow .2s, transform .2s;
}
.ticket.flash{
  animation:flash-pop 1.1s ease;
}
@keyframes flash-pop{
  0%{box-shadow:0 0 0 3px var(--brass), 0 6px 14px var(--shadow);}
  100%{box-shadow:0 6px 14px var(--shadow);}
}
.ticket-head{
  display:flex;justify-content:space-between;align-items:flex-start;gap:.6rem;
  border-bottom:1px dashed var(--line);
  padding-bottom:.55rem;margin-bottom:.6rem;
}
.ticket-head h2{
  font-family:var(--font-display);
  font-size:1.12rem;margin:0 0 .2rem;
  color:var(--pub-green-dark);
}
.ticket-head a{text-decoration:none;}
.ticket-head a:hover{text-decoration:underline;}
.ticket-meta{
  font-family:var(--font-mono);font-size:.72rem;letter-spacing:.5px;
  text-transform:uppercase;color:var(--ink-soft);
}
.district-badge{
  flex:none;
  font-family:var(--font-mono);
  font-size:.68rem;
  border:1px solid var(--pub-green);
  color:var(--pub-green-dark);
  border-radius:999px;
  padding:.2rem .55rem;
  white-space:nowrap;
}
.dist-badges{margin-top:.3rem;display:flex;gap:.4rem;flex-wrap:wrap;}
.dist-badge{
  font-family:var(--font-mono);font-size:.68rem;
  background:var(--paper-deep);border-radius:3px;padding:.15rem .4rem;
  color:var(--ink-soft);
}

ul.item-list{list-style:none;margin:0;padding:0;}
ul.item-list li{
  display:flex;align-items:baseline;gap:.4rem;
  padding:.3rem 0;
  font-size:.92rem;
}
ul.item-list li .item-name{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
ul.item-list li .leader{
  flex:1;border-bottom:1px dotted var(--line);
  transform:translateY(-3px);
  min-width:12px;
}
ul.item-list li .item-price{
  font-family:var(--font-mono);
  font-weight:700;
  color:var(--stamp-red-dark);
  white-space:nowrap;
}
.tag-row{display:flex;gap:.3rem;margin-top:.05rem;}
.tag{
  font-family:var(--font-mono);
  font-size:.6rem;
  text-transform:uppercase;
  letter-spacing:.5px;
  color:var(--ink-soft);
  border-left:2px solid var(--brass);
  padding-left:.3rem;
}
.empty-state{
  grid-column:1/-1;
  text-align:center;
  padding:3rem 1rem;
  font-family:var(--font-mono);
  color:var(--ink-soft);
}

footer{
  max-width:1100px;margin:0 auto 3rem;padding:0 1.5rem;
  font-family:var(--font-mono);font-size:.75rem;color:var(--ink-soft);
  border-top:1px dotted var(--line);padding-top:1rem;
}

@media (max-width:640px){
  .masthead-inner{flex-direction:column;align-items:flex-start;}
  .stamp{width:92px;height:92px;font-size:.9;}
  main.board{grid-template-columns:1fr;}
}
@media (prefers-reduced-motion:reduce){
  *{animation:none !important;transition:none !important;}
}
:focus-visible{outline:2px solid var(--brass);outline-offset:2px;}
</style>
</head>
<body>

<header class="masthead">
  <div class="masthead-inner">
    <div>
      <h1><small>Jídelní lístek · denní menu</small>Menička Praha</h1>
      <p class="tagline">A kiválasztott prágai kerületek aznapi ebédmenüi egy helyen — szűrve, rendezve, gyaloglási idővel.</p>
      <p class="districts">{{ districts.values() | join(' · ') }}</p>
    </div>
    <div class="stamp" aria-hidden="true">
      <div>
        <div class="stamp-label">frissítve</div>
        <div class="stamp-date">{{ updated_str }}</div>
      </div>
    </div>
  </div>
</header>
<div class="perforation" aria-hidden="true"></div>

<div class="toolbar">
  <div class="card-panel">
    <div class="filter-row">
      <div class="filter-group">
        <h3>Kerület</h3>
        <div class="chip-row" id="district-filters">
          {% for slug, label in districts.items() %}
          <button type="button" class="chip" data-filter="district" data-value="{{ slug }}">{{ label }}</button>
          {% endfor %}
        </div>
      </div>

      <div class="filter-group" style="flex:1 1 280px;">
        <h3>Keresés</h3>
        <input type="text" id="keyword-search" class="search-input" placeholder="étel vagy étterem neve…" autocomplete="off">
      </div>

      <div class="filter-group">
        <h3>Ár (Kč)</h3>
        <div class="range-wrap">
          <input type="range" id="price-min" min="{{ price_min }}" max="{{ price_max }}" value="{{ price_min }}" step="5">
          <input type="range" id="price-max" min="{{ price_min }}" max="{{ price_max }}" value="{{ price_max }}" step="5">
        </div>
        <div class="range-values"><span id="price-min-label">{{ price_min }}</span> – <span id="price-max-label">{{ price_max }}</span> Kč</div>
      </div>
    </div>

    <div class="filter-row">
      <div class="filter-group">
        <h3>Kategória</h3>
        <div class="chip-row" id="category-filters">
          <button type="button" class="chip" data-filter="category" data-value="leves">leves</button>
          <button type="button" class="chip" data-filter="category" data-value="főétel">főétel</button>
          <button type="button" class="chip" data-filter="category" data-value="saláta">saláta</button>
          <button type="button" class="chip" data-filter="category" data-value="desszert">desszert</button>
          <button type="button" class="chip" data-filter="category" data-value="ital">ital</button>
        </div>
      </div>

      <div class="filter-group">
        <h3>Konyha típusa</h3>
        <div class="chip-row" id="cuisine-filters">
          <button type="button" class="chip cuisine" data-filter="cuisine" data-value="cseh">cseh</button>
          <button type="button" class="chip cuisine" data-filter="cuisine" data-value="ázsiai">ázsiai</button>
          <button type="button" class="chip cuisine" data-filter="cuisine" data-value="olasz">olasz</button>
          <button type="button" class="chip cuisine" data-filter="cuisine" data-value="mexikói">mexikói</button>
          <button type="button" class="chip cuisine" data-filter="cuisine" data-value="egyéb">egyéb</button>
        </div>
      </div>

      <div class="filter-group">
        <h3>Referenciapont</h3>
        <div class="ref-toggle">
          <label><input type="radio" name="refpoint" value="none" checked>nincs</label>
          <label><input type="radio" name="refpoint" value="A">Pont A<span class="desc">{{ reference_points.A.label.split('–')[0].strip() }}</span></label>
          <label><input type="radio" name="refpoint" value="B">Pont B<span class="desc">{{ reference_points.B.label.split('–')[0].strip() }}</span></label>
        </div>
      </div>
    </div>

    <div class="toolbar-bottom">
      <div style="display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;">
        <label for="sort-select" style="font-family:var(--font-mono);font-size:.78rem;color:var(--ink-soft);">rendezés:</label>
        <select id="sort-select" class="sort-select">
          <option value="value">legjobb ár/érték</option>
          <option value="price-asc">ár szerint ↑</option>
          <option value="price-desc">ár szerint ↓</option>
        </select>
        <button type="button" class="reset-link" id="reset-filters">szűrők törlése</button>
      </div>
      <button type="button" class="btn" id="surprise-btn">🎲 Napi meglepetés</button>
    </div>
  </div>
</div>

<div class="meta-row">
  <div class="result-count" id="result-count">betöltés…</div>
  <div class="result-count">összesen {{ restaurant_count }} étterem, {{ item_count }} étel a lekérés idején</div>
</div>

<main class="board" id="results" aria-live="polite"></main>

<footer>
  Forrás: menicka.cz · a koordináták és a kategorizálás manuálisan karbantartott, fix kulcsszó-szótár alapján készül (nincs AI-hívás a feldolgozásban).
  Utoljára frissítve: {{ updated_str }}.
</footer>

<script id="restaurants-data" type="application/json">{{ restaurants_json }}</script>
<script>
(function(){
  "use strict";

  var RESTAURANTS = JSON.parse(document.getElementById("restaurants-data").textContent);

  var state = {
    districts: new Set(),
    categories: new Set(),
    cuisines: new Set(),
    keyword: "",
    priceMin: {{ price_min }},
    priceMax: {{ price_max }},
    refpoint: "none",
    sort: "value"
  };

  var PRICE_FLOOR = {{ price_min }};
  var PRICE_CEIL = {{ price_max }};

  function stripAccents(s){
    return s.normalize("NFKD").replace(/[\u0300-\u036f]/g, "");
  }
  function norm(s){
    return stripAccents(String(s || "")).toLowerCase();
  }
  function escapeHtml(s){
    return String(s || "").replace(/[&<>"']/g, function(c){
      return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c];
    });
  }

  function mainDishPrice(restaurant){
    var mains = restaurant.items.filter(function(it){ return it.category === "főétel"; });
    var pool = mains.length ? mains : restaurant.items;
    return pool.reduce(function(min, it){ return Math.min(min, it.price); }, Infinity);
  }

  function visibleItemsFor(restaurant){
    var kw = state.keyword;
    var restaurantNameMatches = kw === "" || norm(restaurant.name).indexOf(kw) !== -1;
    return restaurant.items.filter(function(it){
      if (state.categories.size && !state.categories.has(it.category)) return false;
      if (state.cuisines.size && !state.cuisines.has(it.cuisine)) return false;
      if (it.price < state.priceMin || it.price > state.priceMax) return false;
      if (kw !== "" && !restaurantNameMatches && norm(it.name).indexOf(kw) === -1) return false;
      return true;
    });
  }

  function buildCard(restaurant, visibleItems){
    var article = document.createElement("article");
    article.className = "ticket";
    article.dataset.slug = restaurant.slug;

    var distHtml = "";
    if (state.refpoint !== "none") {
      var km = state.refpoint === "A" ? restaurant.distA_km : restaurant.distB_km;
      var min = state.refpoint === "A" ? restaurant.distA_min : restaurant.distB_min;
      if (km !== null && km !== undefined) {
        distHtml = '<div class="dist-badges"><span class="dist-badge">📍 ' + km.toFixed(2) +
          ' km · 🚶 kb. ' + min + ' perc (Pont ' + state.refpoint + ')</span></div>';
      }
    }

    var itemsHtml = visibleItems.map(function(it){
      return (
        '<li>' +
          '<span class="item-name">' + escapeHtml(it.name) + '</span>' +
          '<span class="leader"></span>' +
          '<span class="item-price">' + it.price + ' Kč</span>' +
        '</li>' +
        '<div class="tag-row"><span class="tag">' + escapeHtml(it.category) + '</span><span class="tag">' + escapeHtml(it.cuisine) + '</span></div>'
      );
    }).join("");

    article.innerHTML =
      '<div class="ticket-head">' +
        '<div>' +
          '<h2><a href="' + escapeHtml(restaurant.url) + '" target="_blank" rel="noopener">' + escapeHtml(restaurant.name) + '</a></h2>' +
          '<div class="ticket-meta">' + escapeHtml(restaurant.district) + '</div>' +
          distHtml +
        '</div>' +
        '<span class="district-badge">' + escapeHtml(restaurant.district) + '</span>' +
      '</div>' +
      '<ul class="item-list">' + itemsHtml + '</ul>';

    return article;
  }

  function render(){
    var results = document.getElementById("results");
    results.innerHTML = "";

    var filtered = RESTAURANTS.filter(function(r){
      if (state.districts.size && !state.districts.has(r.districtSlug)) return false;
      return true;
    }).map(function(r){
      return { restaurant: r, visibleItems: visibleItemsFor(r) };
    }).filter(function(entry){
      return entry.visibleItems.length > 0;
    });

    filtered.sort(function(a, b){
      if (state.sort === "value") {
        return mainDishPrice(a.restaurant) - mainDishPrice(b.restaurant);
      }
      var cheapestA = Math.min.apply(null, a.visibleItems.map(function(it){ return it.price; }));
      var cheapestB = Math.min.apply(null, b.visibleItems.map(function(it){ return it.price; }));
      var priciestA = Math.max.apply(null, a.visibleItems.map(function(it){ return it.price; }));
      var priciestB = Math.max.apply(null, b.visibleItems.map(function(it){ return it.price; }));
      if (state.sort === "price-asc") return cheapestA - cheapestB;
      if (state.sort === "price-desc") return priciestB - priciestA;
      return 0;
    });

    if (!filtered.length) {
      var empty = document.createElement("div");
      empty.className = "empty-state";
      empty.textContent = "Nincs a szűrésnek megfelelő találat. Próbáld tágítani a feltételeket.";
      results.appendChild(empty);
    } else {
      filtered.forEach(function(entry){
        results.appendChild(buildCard(entry.restaurant, entry.visibleItems));
      });
    }

    var itemCount = filtered.reduce(function(sum, e){ return sum + e.visibleItems.length; }, 0);
    document.getElementById("result-count").innerHTML =
      "<strong>" + filtered.length + "</strong> étterem &middot; <strong>" + itemCount + "</strong> étel a jelenlegi szűréssel";

    return filtered;
  }

  // --- Chip szűrők (kerület / kategória / konyha) ---
  document.querySelectorAll(".chip[data-filter]").forEach(function(chip){
    chip.addEventListener("click", function(){
      var filter = chip.dataset.filter;
      var value = chip.dataset.value;
      var set = filter === "district" ? state.districts : (filter === "category" ? state.categories : state.cuisines);
      if (set.has(value)) { set.delete(value); chip.classList.remove("active"); }
      else { set.add(value); chip.classList.add("active"); }
      render();
    });
  });

  // --- Kulcsszó keresés ---
  var searchInput = document.getElementById("keyword-search");
  searchInput.addEventListener("input", function(){
    state.keyword = norm(searchInput.value.trim());
    render();
  });

  // --- Ár csúszka (két végű) ---
  var priceMinInput = document.getElementById("price-min");
  var priceMaxInput = document.getElementById("price-max");
  var priceMinLabel = document.getElementById("price-min-label");
  var priceMaxLabel = document.getElementById("price-max-label");

  function syncPriceInputs(){
    var lo = parseInt(priceMinInput.value, 10);
    var hi = parseInt(priceMaxInput.value, 10);
    if (lo > hi) { var tmp = lo; lo = hi; hi = tmp; }
    state.priceMin = lo;
    state.priceMax = hi;
    priceMinLabel.textContent = lo;
    priceMaxLabel.textContent = hi;
    render();
  }
  priceMinInput.addEventListener("input", syncPriceInputs);
  priceMaxInput.addEventListener("input", syncPriceInputs);

  // --- Referenciapont váltó ---
  document.querySelectorAll('input[name="refpoint"]').forEach(function(radio){
    radio.addEventListener("change", function(){
      state.refpoint = radio.value;
      render();
    });
  });

  // --- Rendezés ---
  document.getElementById("sort-select").addEventListener("change", function(e){
    state.sort = e.target.value;
    render();
  });

  // --- Szűrők törlése ---
  document.getElementById("reset-filters").addEventListener("click", function(){
    state.districts.clear();
    state.categories.clear();
    state.cuisines.clear();
    state.keyword = "";
    state.priceMin = PRICE_FLOOR;
    state.priceMax = PRICE_CEIL;
    state.refpoint = "none";
    state.sort = "value";

    document.querySelectorAll(".chip.active").forEach(function(c){ c.classList.remove("active"); });
    searchInput.value = "";
    priceMinInput.value = PRICE_FLOOR;
    priceMaxInput.value = PRICE_CEIL;
    priceMinLabel.textContent = PRICE_FLOOR;
    priceMaxLabel.textContent = PRICE_CEIL;
    document.querySelector('input[name="refpoint"][value="none"]').checked = true;
    document.getElementById("sort-select").value = "value";

    render();
  });

  // --- Napi meglepetés ---
  document.getElementById("surprise-btn").addEventListener("click", function(){
    var currentlyVisible = document.querySelectorAll("#results .ticket");
    if (!currentlyVisible.length) return;
    var pick = currentlyVisible[Math.floor(Math.random() * currentlyVisible.length)];
    pick.scrollIntoView({ behavior: "smooth", block: "center" });
    pick.classList.remove("flash");
    void pick.offsetWidth; // reflow, hogy az animáció újra elinduljon
    pick.classList.add("flash");
  });

  render();
})();
</script>
</body>
</html>
